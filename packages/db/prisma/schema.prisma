// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String         @id @default(uuid())
  address    String         @unique
  usdBalance Int
  positions  Position[]
  orders     OrderHistory[]
  comments   Comment[]
  @@index([address])
}

model Market {
  id                    String         @id @default(uuid())
  title                 String
  description           String
  resolutionDescription String
  yesOrderbook          Json
  noOrderbook           Json
  totalQty              Int
  positions             Position[]
  orders                OrderHistory[]
  resolution            PositionType?
  category              MarketCategory @default(World)
  endDate               DateTime?
  trending              Boolean        @default(false)
  comments              Comment[]

  @@index([category])
  @@index([endDate])
}

model Comment {
  id        String   @id @default(uuid())
  content   String
  userId    String
  marketId  String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  market    Market   @relation(fields: [marketId], references: [id])

  @@index([marketId, createdAt])
}

model Position {
  id       String       @id @default(uuid())
  userId   String
  marketId String
  type     PositionType
  user     User         @relation(fields: [userId], references: [id])
  market   Market       @relation(fields: [marketId], references: [id])
  qty      Int
  @@unique([userId, marketId, type])
}

model OrderHistory {
  id        String        @id @default(uuid())
  orderType OrderType
  side      PositionType?
  qty       Int
  price     Int
  userId    String
  marketId  String
  createdAt DateTime      @default(now())
  user      User          @relation(fields: [userId], references: [id])
  market    Market        @relation(fields: [marketId], references: [id])

  @@index([marketId, createdAt])
}

enum PositionType {
  Yes
  No
}

enum OrderType {
  Buy
  Sell
  Split
  Merge
}

enum MarketCategory {
  Politics
  Crypto
  Sports
  AI
  Finance
  Technology
  Entertainment
  Economy
  Elections
  World
}
